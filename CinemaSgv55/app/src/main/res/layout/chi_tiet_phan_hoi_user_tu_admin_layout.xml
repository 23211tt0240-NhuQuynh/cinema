<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="48dp"
        android:src="@drawable/ic_back"
        app:tint="#F44336"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phản hồi từ Admin"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginStart="64dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtTieuDe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tiêu đề"
        android:textStyle="bold"

        android:textSize="18sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView

        android:id="@+id/txtThoiGian"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Thời gian"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtTieuDe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView

        android:id="@+id/txtNoiDung"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="#EEEEEE"
        android:padding="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtThoiGian"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtPhanHoi"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:background="#E8F5E9"
        android:padding="12dp"
        android:text="Admin chưa phản hồi"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtNoiDung"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>