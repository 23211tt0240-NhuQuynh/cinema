<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        >

        <!-- HEADER -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="48dp"
            android:src="@drawable/ic_back"
            app:tint="#F44336"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Theo dõi hạng thành viên"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#D32F2F"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            android:layout_marginStart="12dp"/>

        <!-- MAIN CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#EEEEEE"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- USER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@android:drawable/sym_def_app_icon"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xin chào,"
                            android:textColor="#777777"/>

                        <TextView
                            android:id="@+id/txtName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="Nguyễn Như Quỳnh"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#111111"/>

                        <TextView
                            android:id="@+id/txtRank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MEMBER"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:layout_marginTop="8dp"
                            android:background="#D32F2F"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- ĐIỂM -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Điểm thành viên"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"/>

                <TextView
                    android:id="@+id/txtPoint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="1500 điểm"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"/>

                <ProgressBar
                    android:id="@+id/progressMember"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="3000"
                    android:progress="0"
                    android:layout_marginTop="12dp"
                    android:progressTint="#D32F2F"
                    android:progressBackgroundTint="#E0E0E0"/>

                <!-- THỐNG KÊ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#FFF5F5">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tổng số vé"
                                android:textColor="#777777"/>

                            <TextView
                                android:id="@+id/txtTongVe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="8 vé"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#D32F2F"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#FFF5F5">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tổng chi tiêu"
                                android:textColor="#777777"/>

                            <TextView
                                android:id="@+id/txtTongChi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="1,500,000đ"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#D32F2F"/>
                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- TAB -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:weightSum="4">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tabU22"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="14dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeColor="#DDDDDD">

                        <TextView
                            android:id="@+id/txtU22"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="U22"
                            android:gravity="center"
                            android:textStyle="bold"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tabMember"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="14dp"
                        app:strokeColor="#DDDDDD">

                        <TextView
                            android:id="@+id/txtMember"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="MEMBER"
                            android:gravity="center"
                            android:textStyle="bold"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tabElite"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="14dp"
                        app:strokeColor="#DDDDDD">

                        <TextView
                            android:id="@+id/txtElite"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="ELITE"
                            android:gravity="center"
                            android:textStyle="bold"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tabVip"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="14dp"
                        app:strokeColor="#DDDDDD">

                        <TextView
                            android:id="@+id/txtVip"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="VIP"
                            android:gravity="center"
                            android:textStyle="bold"/>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- NỘI DUNG ĐẶC QUYỀN -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#FFF8F8">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/txtPrivilegeTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đặc quyền MEMBER"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#D32F2F"/>

                        <TextView
                            android:id="@+id/txtPrivilegeContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="✓ Giảm 5% giá vé&#10;✓ Voucher hàng tháng&#10;✓ Tích điểm thành viên"
                            android:textSize="15sp"
                            android:textColor="#333333"/>
                        <Button
                            android:id="@+id/btnDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Thông tin chi tiết"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:backgroundTint="#D32F2F"/>

                    </LinearLayout>


                </com.google.android.material.card.MaterialCardView>


            </LinearLayout>


        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>